{
  // ═══════════════════════════════════════════════════════════════════════════
  // appsettings.json — Boot Configuration
  //
  // This file is read at startup by the App class (App.axaml.cs).
  // It provides the initial application settings before the user's
  // personal settings are loaded from %APPDATA%\Colair\settings.json.
  //
  // The main settings (API keys, providers, model selections) are stored
  // in the user's settings file. This file just provides boot defaults.
  //
  // Settings here:
  //   ActiveProvider — Which AI provider is selected by default ("OpenAi")
  //   SsaaFactor     — Default rendering quality (1.0 = native resolution)
  //   MaxRetries     — How many times the AI tries to fix its own shader code
  // ═══════════════════════════════════════════════════════════════════════════
  "AppSettings": {
    "ActiveProvider": "OpenAi",     // Default AI provider key name
    "SsaaFactor": 1.0,              // 1.0 = native, 1.5 = HD, 2.0 = Ultra HD
    "MaxRetries": 5                 // Self-healing retry limit
  }
}
